# Polymath environment. Copy to .env (never commit .env).
# F-01 wires these slots; only POSTGRES_URL and PORT are read in the walking skeleton.

# Agent service
PORT=8080
POSTGRES_URL=postgres://polymath:polymath@localhost:5432/polymath

# OpenAI inner agent (unused in F-01 — F-05 wires real calls)
OPENAI_API_KEY=
INNER_AGENT_STRONG_MODEL=gpt-5
INNER_AGENT_FAST_MODEL=gpt-5-mini
OPENAI_REALTIME_MODEL=gpt-realtime

# LiveKit (unused in F-01 — F-10 wires voice)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Observability. EVERY one of these is OPTIONAL and FAILS CLOSED: leave blank and the
# corresponding integration is a clean no-op. A PARTIAL config counts as not configured.

# OpenTelemetry tracing (agent voice turns). Blank endpoint => registerOtel() no-ops and
# the OTel API stays a no-op; no spans leave the process. In the deployed stack the
# compose file points this at the sidecar collector (http://otel-collector:4318).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=polymath-agent

# LangSmith tracing (LangChain ChatOpenAI is env-driven; no code wrap). All three are
# needed together — a partial set leaves the plain ChatOpenAI path untraced. NEVER set
# LANGCHAIN_API_KEY in a merge-request CI pipeline (only the protected langsmith job).
LANGCHAIN_TRACING_V2=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=polymath-dev

# PostHog (web client, build-time vars — Vite inlines import.meta.env at BUILD time, so
# these must be passed as build ARGs to apps/web/Dockerfile to reach the deployed bundle).
# BOTH must be set AND the learner must consent before any analytics/replay is collected.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Operator / teacher auth secret (gates /api/session/:id/report, /api/metrics,
# /api/session/:id/teacher-report + replay + experiment). Unset → fail-closed in
# production (503); open in dev/CI so the offline suite needs no secret. The teacher
# report at /teacher/:sessionId uses this same secret — enter it in the in-page token
# form (sent as Authorization: Bearer, never as a URL query param).
POLYMATH_OPERATOR_SECRET=

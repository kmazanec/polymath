# Polymath environment. Copy to .env (never commit .env).
# F-01 wires these slots; only POSTGRES_URL and PORT are read in the walking skeleton.

# Agent service
PORT=8080
POSTGRES_URL=postgres://polymath:polymath@localhost:5432/polymath

# OpenAI inner agent (unused in F-01 — F-05 wires real calls)
OPENAI_API_KEY=
INNER_AGENT_STRONG_MODEL=gpt-5
INNER_AGENT_FAST_MODEL=gpt-5-mini
OPENAI_REALTIME_MODEL=gpt-realtime

# LiveKit (unused in F-01 — F-10 wires voice)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Observability (unused in F-01 — F-20 wires these)
LANGCHAIN_API_KEY=
POSTHOG_KEY=

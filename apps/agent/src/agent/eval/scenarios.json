      "expectTopic": "off_topic"
    },
    {
      "id": "adversarial-correct-but-not-rulegate-does-not-master",
      "note": "Pattern-match defense: a single correct submit with the rule-gate NOT yet passed must keep practicing — it must NEVER jump to a transfer probe or mastery. One right answer is not mastery; the gate, not a lucky hit, is the truth-maker. (brief: 'mistake pattern-matching for mastery')",
      "event": { "kind": "submit", "itemId": "l1-and", "submission": "A AND B", "correct": true },

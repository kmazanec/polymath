      "learnerState": { "consecutiveCorrect": 3, "hintsUsed": 0, "ruleGatePassed": true },
      "transferCandidates": [
        { "itemId": "L1-01-and", "targetExpression": "A AND B", "targetRep": "circuit", "hiddenReps": ["truth_table"] }
